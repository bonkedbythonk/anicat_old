#!/usr/bin/env bash
# post-commit — Create and push a git tag after a version-bumping commit.
#
# Runs AFTER the commit is created. If the version changed, creates a
# lightweight tag matching the new version so that `release.yml` (which
# triggers on `v*` tags) fires automatically.
#
# Works alongside the `pre-commit` hook which bumps version files:
#   pre-commit  → bumps version.txt & stages files
#   commit      → creates the commit with the new version
#   post-commit → tags the commit with v{new_version}
#
# The tag is NOT auto-pushed — the user pushes normally with `git push --tags`
# or the CI pushes it for you (see nightly.yml).
#
# Install: git config core.hooksPath .githooks

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VERSION_FILE="$PROJECT_ROOT/version.txt"

# Get the commit SHA we just created
NEW_COMMIT=$(git rev-parse HEAD)

# Read the current version
if [ ! -f "$VERSION_FILE" ]; then
    exit 0
fi

VERSION=$(cat "$VERSION_FILE" | tr -d '[:space:]')
if [ -z "$VERSION" ]; then
    exit 0
fi

# Check if the tag already exists
TAG="v${VERSION}"
if git tag -l "$TAG" | grep -q .; then
    # Tag already exists — likely this was a tag push, skip
    exit 0
fi

# Check if this is master or nightly branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Create the tag
git tag "$TAG" "$NEW_COMMIT" 2>/dev/null || true

echo "[post-commit] Created tag: $TAG on $BRANCH"

# On master, also update/replace the stable tag
if [ "$BRANCH" = "master" ]; then
    # Delete the old stable tag locally if it exists
    git tag -d "${TAG}-stable" 2>/dev/null || true
    # Create new stable tag
    git tag "v${VERSION}-stable" "$NEW_COMMIT" 2>/dev/null || true
    echo "[post-commit] Updated stable tag: v${VERSION}-stable"
fi

# On nightly, update the nightly tag
if [ "$BRANCH" = "nightly" ]; then
    git tag -d "nightly" 2>/dev/null || true
    git tag "nightly" "$NEW_COMMIT" 2>/dev/null || true
    echo "[post-commit] Updated nightly tag"
fi
